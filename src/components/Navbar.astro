---
import LiquidButton from "./LiquidButton.astro";
import Logo from "./Logo.astro";
---

<nav class="nav">
  <a href="#home">
    <Logo />
  </a>
  <ul>
    <li id="hello"><a href="#projects"><LiquidButton title="Projects" /></a></li>
    <li><a href="#about"><LiquidButton title="About" /></a></li>
    <li id="getInTouch"><a href="#getintouch"><LiquidButton title="Get in touch" /></a></li>
  </ul>
</nav>
<style>
  p {
    margin-bottom: 10%;
    font-size: 2.5rem;
    color: black;
    font-weight: 500;
  }

  a {
    text-decoration: none;
  }

  .nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    /* border-bottom: 1px solid #000000; */
    height: 75px;
    position: fixed;
    width: 100%;
    top: 0px;
    z-index: 10;
    background: blur;
    box-shadow: 0px 0px 10px 0px rgba(0, 0, 0, 0.5);
    
  }

  ul {
    display: flex;
    list-style: none;
    color: rgba(255, 255, 255, 0);
    flex-direction: row;
    align-items: flex-end;
    justify-content: flex-end;
    height: 100%;
    width: 100%;

  }
  li {
    margin-left: 1rem;
    height: 100%;
    width: 180px;
  }

  #getInTouch {
    margin-right: 0px;
    width: 25%;
  }
</style>
