---
import ContactMe from "./ContactMe.astro";
import Logo from "./Logo.astro";
---

<nav class="nav">
  <a href="https://tadiwapfachi.dev">
    <Logo />
  </a>
  <ul>
    <li id="hello"><a href="#projects"><ContactMe title="Projects" /></a></li>
    <li><a href="#about"><ContactMe title="About" /></a></li>
    <li><a href="#contact"><ContactMe title="Get in touch" /></a></li>
  </ul>
</nav>
<style>
  p {
    margin-bottom: 10%;
    font-size: 2.5rem;
    color: black;
    font-weight: 500;
  }

  a {
    text-decoration: none;
  }

  .nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid #000000;
    height: 100px;
    position: fixed;
    width: 100%;
    top: 0px;
  }

  ul {
    list-style: none;
    color: rgba(255, 255, 255, 0);
    flex-direction: row;
    align-items: center;
    height: 100%;
    background-color: aliceblue;
    width: 100%;
  }
  li {
    margin-left: 1rem;
    height: 100%;
    width: 180px;
  }
</style>
